[
  {
    "description": "List background jobs in the current shell",
    "command": "jobs"
  },
  {
    "description": "List background jobs with their PIDs",
    "command": "jobs -l"
  },
  {
    "description": "List only running background jobs",
    "command": "jobs -r"
  },
  {
    "description": "List only stopped background jobs",
    "command": "jobs -s"
  }
]
