[
  {
    "description": "Select specific pages from a PDF",
    "command": "cpdf <input> <page_spec> -o <output>",
    "defaults": {
      "page_spec": "1-3,6"
    },
    "params": {
      "input": {
        "type": "existing_file",
        "description": "Source PDF"
      },
      "page_spec": {
        "type": "string",
        "description": "Page spec (e.g. 1-3,6 or 'even' or 'odd' or '2-end')"
      },
      "output": {
        "type": "path",
        "description": "Destination PDF"
      }
    }
  },
  {
    "description": "Merge multiple PDFs into one",
    "command": "cpdf -merge <inputs> -o <output>",
    "params": {
      "inputs": {
        "type": "existing_file_list",
        "description": "PDF files to merge in order"
      },
      "output": {
        "type": "path",
        "description": "Destination PDF"
      }
    }
  },
  {
    "description": "Split a PDF into N-page chunks",
    "command": "cpdf -split <input> -o <output_pattern> -chunk <chunk_size>",
    "defaults": {
      "output_pattern": "Chunk%%%.pdf",
      "chunk_size": "10"
    },
    "params": {
      "input": {
        "type": "existing_file",
        "description": "Source PDF"
      },
      "output_pattern": {
        "type": "string",
        "description": "Output filename pattern with %%% for the index"
      },
      "chunk_size": {
        "type": "integer",
        "description": "Pages per chunk"
      }
    }
  },
  {
    "description": "Split a PDF on bookmark boundaries",
    "command": "cpdf -split-bookmarks 0 <input> -o '@N.pdf'",
    "params": {
      "input": {
        "type": "existing_file",
        "description": "Source PDF"
      }
    }
  },
  {
    "description": "Scale a PDF's pages by a factor",
    "command": "cpdf -scale-page \"<sx> <sy>\" <input> -o <output>",
    "defaults": {
      "sx": "2",
      "sy": "2"
    },
    "params": {
      "sx": {
        "description": "X-axis scale factor"
      },
      "sy": {
        "description": "Y-axis scale factor"
      },
      "input": {
        "type": "existing_file",
        "description": "Source PDF"
      },
      "output": {
        "type": "path",
        "description": "Destination PDF"
      }
    }
  },
  {
    "description": "Scale a PDF to fit a standard paper size",
    "command": "cpdf -scale-to-fit <paper> <input> -o <output>",
    "defaults": {
      "paper": "usletterportrait"
    },
    "params": {
      "paper": {
        "description": "Paper size (e.g. usletterportrait, a4portrait)"
      },
      "input": {
        "type": "existing_file",
        "description": "Source PDF"
      },
      "output": {
        "type": "path",
        "description": "Destination PDF"
      }
    }
  },
  {
    "description": "Rotate pages by an angle",
