        "type": "existing_file",
        "description": "Source PDF"
      },
      "output": {
        "type": "path",
        "description": "Destination PDF"
      }
    }
  },
  {
    "description": "Encrypt a PDF with 128-bit encryption",
    "command": "cpdf -encrypt 128bit <owner_pw> <user_pw> <input> -o <output>",
    "params": {
      "owner_pw": {
        "type": "string",
        "description": "Owner password"
      },
      "user_pw": {
        "type": "string",
        "description": "User password"
      },
      "input": {
        "type": "existing_file",
        "description": "Source PDF"
      },
      "output": {
        "type": "path",
        "description": "Destination PDF"
      }
    }
  },
  {
    "description": "Decrypt a PDF using the owner password",
    "command": "cpdf -decrypt <input> owner=<owner_pw> -o <output>",
    "params": {
      "input": {
        "type": "existing_file",
