[
  {
    "description": "Remount the root filesystem as read-write (repair mode)",
    "command": "sudo mount -o remount,rw /"
  },
  {
    "description": "Bind-mount one path at another location",
    "command": "sudo mount --bind <source> <destination>",
    "params": {
      "source": {
        "type": "existing_path",
        "description": "Source path"
      },
      "destination": {
        "type": "existing_dir",
        "description": "Mount target"
      }
    }
  },
  {
    "description": "Mount a USB disk owned by a specific user/group",
    "command": "sudo mount -o uid=<user>,gid=<group> <device> <destination>",
    "params": {
      "user": {
        "description": "Owner username"
      },
      "group": {
        "description": "Owner group name"
      },
      "device": {
        "description": "Block device (e.g. /dev/sdb1)"
      },
      "destination": {
        "type": "existing_dir",
        "description": "Mount target"
      }
    }
  },
  {
    "description": "Mount a remote NFS share",
    "command": "sudo mount -t nfs <host>:<remote_dir> <local_dir>",
    "params": {
      "host": {
        "description": "NFS server hostname or IP"
      },
      "remote_dir": {
        "description": "Exported path on the server"
      },
      "local_dir": {
        "type": "existing_dir",
        "description": "Local mount point"
      }
    }
  },
  {
    "description": "Mount an ISO file as a loopback device",
    "command": "sudo mount -o loop <iso_file> <mount_point>",
    "params": {
      "iso_file": {
        "type": "existing_file",
        "description": "ISO file path"
      },
      "mount_point": {
        "type": "existing_dir",
        "description": "Mount point"
      }
    }
  },
  {
    "description": "Show all currently mounted filesystems",
    "command": "mount"
  }
]
