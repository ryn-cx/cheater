[
  {
    "description": "Test a URL with POST data and try to print the database banner",
    "command": "sqlmap --url=\"<url>\" --data=\"<post_data>\" --banner",
    "params": {
      "url": {
        "type": "string",
        "description": "Target URL"
      },
      "post_data": {
        "type": "string",
        "description": "POST body parameters"
      }
    }
  },
  {
    "description": "Test using a saved HTTP request file",
    "command": "sqlmap -r <request_file>",
    "params": {
      "request_file": {
        "type": "existing_file",
        "description": "Saved HTTP request"
      }
    }
  },
  {
    "description": "Fingerprint the backend DB (more info than --banner)",
    "command": "sqlmap -r <request_file> --fingerprint",
    "params": {
      "request_file": {
        "type": "existing_file",
        "description": "Saved HTTP request"
      }
    }
  },
  {
    "description": "Get the current DB user, current database, and server hostname",
