        "description": "File or directory to archive"
      }
    }
  },
  {
    "description": "List the contents of a .tar.gz archive",
    "command": "tar -tzvf <archive>",
    "params": {
      "archive": {
        "type": "existing_file",
        "description": "Archive file"
      }
    }
  },
  {
    "description": "Extract a .tar.bz2 archive",
