[
  {
    "description": "Extract an uncompressed .tar archive",
    "command": "tar -xvf <archive>",
    "params": {
      "archive": {
        "type": "existing_file",
        "description": "Archive file"
      }
    }
  },
  {
    "description": "Extract a .tar into a specific directory",
    "command": "tar -xvf <archive> -C <destination>",
    "params": {
      "archive": {
        "type": "existing_file",
        "description": "Archive file"
      },
      "destination": {
        "type": "existing_dir",
        "description": "Where to extract"
      }
    }
  },
  {
    "description": "Create an uncompressed .tar archive",
    "command": "tar -cvf <archive> <source>",
    "params": {
      "archive": {
        "type": "path",
        "description": "Output archive path"
      },
      "source": {
        "type": "existing_path",
        "description": "File or directory to archive"
      }
    }
  },
  {
    "description": "Extract a .tar.gz / .tgz archive",
    "command": "tar -xzvf <archive>",
    "params": {
      "archive": {
        "type": "existing_file",
        "description": "Archive file"
      }
    }
  },
  {
    "description": "Create a .tar.gz archive",
