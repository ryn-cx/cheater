    "params": {
      "archive": {
        "type": "existing_file",
        "description": "Archive file"
      }
    }
  },
  {
    "description": "Create a .tar.bz2 archive",
    "command": "tar -cjvf <archive> <source>",
    "params": {
      "archive": {
        "type": "path",
        "description": "Output .tar.bz2 path"
      },
      "source": {
        "type": "existing_path",
        "description": "File or directory to archive"
      }
    }
  },
  {
    "description": "Create a .tar.gz excluding certain glob patterns",
    "command": "tar -czvf <archive> --exclude=<pattern> <source>",
    "params": {
      "archive": {
        "type": "path",
        "description": "Output .tgz path"
      },
      "pattern": {
        "type": "string",
        "description": "Exclude glob (e.g. '*.tmp')"
      },
      "source": {
        "type": "existing_path",
        "description": "File or directory to archive"
      }
    }
  },
  {
    "description": "Append a file to an existing .tar archive",
    "command": "tar -rf <archive> <file>",
    "params": {
      "archive": {
        "type": "existing_file",
        "description": "Existing .tar archive"
      },
      "file": {
        "type": "existing_file",
        "description": "File to append"
      }
    }
  }
