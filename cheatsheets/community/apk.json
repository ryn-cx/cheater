[
  {
    "description": "Install a package",
    "command": "apk add <package>",
    "params": {
      "package": {
        "description": "Package name (space-separated for multiple)"
      }
    }
  },
  {
    "description": "Remove a package",
    "command": "apk del <package>",
    "params": {
      "package": {
        "description": "Package name to remove"
      }
    }
  },
  {
    "description": "Update repository indexes",
    "command": "apk update"
  },
  {
    "description": "Upgrade all installed packages",
    "command": "apk upgrade"
  },
  {
    "description": "Search for a package",
    "command": "apk search <package>",
    "params": {
      "package": {
        "description": "Package name or pattern to search for"
      }
    }
  }
]
