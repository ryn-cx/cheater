[
  {
    "description": "Copy a file",
    "command": "cp <source> <destination>",
    "params": {
      "source": {
        "type": "existing_file",
        "description": "Source file"
      },
      "destination": {
        "type": "path",
        "description": "Destination path"
      }
    }
  },
  {
    "description": "Copy a directory recursively",
    "command": "cp -r <source> <destination>",
    "params": {
      "source": {
        "type": "existing_dir",
        "description": "Source directory"
      },
      "destination": {
        "description": "Destination directory"
      }
    }
  },
  {
    "description": "Copy a file, prompting if destination exists",
    "command": "cp -i <source> <destination>",
    "params": {
      "source": {
        "type": "existing_file",
        "description": "Source file"
      },
      "destination": {
        "type": "path",
        "description": "Destination path"
      }
    }
  },
  {
    "description": "Make a timestamped backup copy of a file",
    "command": "cp <file>{,.\"$(date +%Y%m%d-%H%M%S)\"}",
    "params": {
      "file": {
        "type": "existing_file",
        "description": "File to back up (the suffix .YYYYMMDD-HHMMSS is added)"
      }
    }
  },
  {
    "description": "Copy a symlink as a symlink (don't follow it)",
    "command": "cp -P <symlink> <destination>",
    "params": {
      "symlink": {
        "description": "Symlink to copy"
      },
      "destination": {
        "type": "path",
        "description": "Destination path"
      }
    }
  },
  {
    "description": "Copy sparsely (preserve sparse regions)",
    "command": "cp --sparse=always <source> <destination>",
    "params": {
      "source": {
        "type": "existing_file",
        "description": "Source file"
      },
      "destination": {
        "type": "path",
        "description": "Destination path"
      }
    }
  }
]
